{
	"name": "@ulixee/datastore",
	"main": "index.js",
	"repository": "git@github.com:ulixee/platform.git",
	"license": "MIT",
	"bin": "./bin/cli.js",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"import": "./index.mjs",
			"require": "./index.cjs"
		},
		"./*": "./*.js",
		"./package.json": "./package.json",
		"./lib/*": {
			"types": "./lib/*.d.ts",
			"require": "./lib/*.js"
		},
		"./cli/*": "./cli/*.js",
		"./storage-engines/*": {
			"types": "./storage-engines/*.d.ts",
			"require": "./storage-engines/*.js"
		},
		"./payments/*": {
			"types": "./payments/*.d.ts",
			"require": "./payments/*.js"
		},
		"./connections/*": {
			"types": "./connections/*.d.ts",
			"require": "./connections/*.js"
		},
		"./types/*": {
			"types": "./types/*.d.ts",
			"require": "./types/*.js"
		},
		"./interfaces/*": {
			"types": "./interfaces/*.d.ts",
			"require": "./interfaces/*.js"
		}
	},
	"dependencies": {
		"@argonprotocol/localchain": "~1.0",
		"@argonprotocol/mainchain": "~1.0",
		"@ulixee/commons": "workspace:*",
		"@ulixee/net": "workspace:*",
		"@ulixee/platform-specification": "workspace:*",
		"@ulixee/platform-utils": "workspace:*",
		"@ulixee/schema": "workspace:*",
		"@ulixee/sql-ast": "workspace:*",
		"@ulixee/sql-engine": "workspace:*",
		"better-sqlite3": "^11.1.2",
		"commander": "^9.5.0",
		"moment": "^2.29.4",
		"nanoid": "^3.3.11"
	},
	"devDependencies": {
		"@ulixee/datastore-packager": "workspace:*",
		"@ulixee/datastore-testing": "workspace:*"
	}
}
