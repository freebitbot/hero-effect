{
	"name": "@ulixee/hero",

	"description": "The client interface for Hero",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"import": "./index.mjs",
			"require": "./index.cjs"
		},
		"./lib/*": {
			"types": "./lib/*.d.ts",
			"default": "./lib/*.js",
			"require": "./lib/*.js"
		},
		"./connections/*": {
			"types": "./connections/*.d.ts",
			"default": "./connections/*.js",
			"require": "./connections/*.js"
		}
	},
	"dependencies": {
		"@ulixee/awaited-dom": "1.4.2",
		"@ulixee/commons": "workspace:*",
		"@ulixee/hero-interfaces": "workspace:*",
		"@ulixee/hero-plugin-utils": "workspace:*",
		"@ulixee/js-path": "workspace:*",
		"@ulixee/net": "workspace:*",
		"@ulixee/unblocked-specification": "workspace:*",
		"linkedom": "^0.14.11"
	},
	"devDependencies": {
		"@ulixee/hero-core": "workspace:*",
		"@ulixee/hero-testing": "workspace:*"
	}
}
