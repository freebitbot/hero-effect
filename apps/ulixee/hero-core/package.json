{
	"name": "@ulixee/hero-core",

	"description": "The core browser API used to run Hero",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"import": "./index.mjs",
			"require": "./index.cjs"
		},
		"./package.json": "./package.json",
		"./lib/*": {
			"types": "./lib/*.d.ts",
			"require": "./lib/*.js"
		},
		"./dbs": "./dbs",
		"./dbs/*": {
			"types": "./dbs/*.d.ts",
			"require": "./dbs/*.js"
		},
		"./models/*": {
			"types": "./models/*.d.ts",
			"require": "./models/*.js"
		},
		"./connections/*": {
			"types": "./connections/*.d.ts",
			"require": "./connections/*.js"
		},
		"./apis/*": {
			"types": "./apis/*.d.ts",
			"require": "./apis/*.js"
		}
	},
	"dependencies": {
		"@ulixee/awaited-dom": "1.4.2",
		"@ulixee/commons": "workspace:*",
		"@ulixee/default-browser-emulator": "workspace:*",
		"@ulixee/default-human-emulator": "workspace:*",
		"@ulixee/hero-interfaces": "workspace:*",
		"@ulixee/hero-plugin-utils": "workspace:*",
		"@ulixee/hero-timetravel": "workspace:*",
		"@ulixee/js-path": "workspace:*",
		"@ulixee/net": "workspace:*",
		"@ulixee/unblocked-agent": "workspace:*",
		"@ulixee/unblocked-agent-mitm": "workspace:*",
		"@ulixee/unblocked-specification": "workspace:*",
		"better-sqlite3": "^11.1.2",
		"moment": "^2.29.4",
		"nanoid": "^3.3.11",
		"ws": "^8.18.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.11",
		"@ulixee/chrome-app": "1.0.3",
		"@ulixee/hero": "workspace:*",
		"@ulixee/hero-testing": "workspace:*"
	}
}
